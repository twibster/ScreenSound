<wpfui:UiWindow x:Class="AudioMonitorRouter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:AudioMonitorRouter.ViewModels"
        Title="Audio Monitor Router"
        Height="720" Width="900"
        MinHeight="560" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <wpfui:UiWindow.Resources>
        <!-- Sidebar nav button style (accent bar only, no box) -->
        <Style x:Key="SidebarNavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="Transparent" Padding="0,14">
                            <Grid>
                                <Border x:Name="Indicator" Width="3" Height="16"
                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                        CornerRadius="0,2,2,0" Background="Transparent"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </wpfui:UiWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Sidebar: no background — raw Mica shows through (darkest surface) -->

        <!-- Content panel: translucent raised sheet over Mica, rounded top-left corner -->
        <Border Grid.Column="1" Grid.Row="1" CornerRadius="8,0,0,0"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>

        <!-- ── TITLE BAR ── -->
        <wpfui:TitleBar Grid.ColumnSpan="2" Grid.Row="0"
                        Title="Audio Monitor Router"
                        ShowMinimize="True" ShowMaximize="True" ShowClose="True"/>

        <!-- ── SIDEBAR ── -->
        <DockPanel Grid.Column="0" Grid.Row="1" LastChildFill="False">
            <RadioButton DockPanel.Dock="Top" GroupName="Nav" IsChecked="True"
                         Checked="NavButton_Checked" Tag="0"
                         Style="{StaticResource SidebarNavButton}">
                <StackPanel HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="Home24" FontSize="22" HorizontalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    <TextBlock Text="Home" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton DockPanel.Dock="Top" GroupName="Nav"
                         Checked="NavButton_Checked" Tag="1"
                         Style="{StaticResource SidebarNavButton}">
                <StackPanel HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="Pin24" FontSize="22" HorizontalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    <TextBlock Text="Pinned" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton DockPanel.Dock="Bottom" GroupName="Nav"
                         Checked="NavButton_Checked" Tag="3"
                         Style="{StaticResource SidebarNavButton}">
                <StackPanel HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="Info24" FontSize="22" HorizontalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    <TextBlock Text="About" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton DockPanel.Dock="Bottom" GroupName="Nav"
                         Checked="NavButton_Checked" Tag="2"
                         Style="{StaticResource SidebarNavButton}">
                <StackPanel HorizontalAlignment="Center">
                    <wpfui:SymbolIcon Symbol="Settings24" FontSize="22" HorizontalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    <TextBlock Text="Settings" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </StackPanel>
            </RadioButton>
        </DockPanel>

        <!-- ── CONTENT AREA ── -->
        <Grid Grid.Column="1" Grid.Row="1" ClipToBounds="True">

            <!-- ═══ HOME PAGE ═══ -->
            <Border x:Name="HomePage" Visibility="Collapsed" Opacity="0">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Fixed top section: Audio Routing + Monitor Mappings + Sessions header -->
                    <StackPanel Grid.Row="0" Margin="24,20,24,0">
                        <wpfui:CardControl Margin="0,0,0,20">
                            <wpfui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="Speaker224" FontSize="22"
                                                      Margin="0,0,14,0" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Audio Routing" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Route audio based on monitor placement" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl.Header>
                            <wpfui:ToggleSwitch IsChecked="{Binding IsRoutingEnabled}"/>
                        </wpfui:CardControl>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Monitor Mappings" FontSize="20" FontWeight="Medium" VerticalAlignment="Center"/>
                            <wpfui:Button Grid.Column="1" Icon="ArrowClockwise24" Appearance="Transparent"
                                          Command="{Binding RefreshCommand}" ToolTip="Refresh monitors and audio devices"
                                          Width="32" Height="32"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Monitors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <wpfui:Card Margin="0,0,0,8" Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Monitor icon -->
                                            <wpfui:SymbolIcon Grid.Column="0" Symbol="Desktop24" FontSize="24"
                                                              Margin="0,0,14,0" VerticalAlignment="Center"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                            <!-- Monitor info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                    <Border Margin="8,0,0,0" Padding="8,2" CornerRadius="4"
                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                            Visibility="{Binding Monitor.IsPrimary, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="PRIMARY" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Monitor.DeviceName}" FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Device selector + volume -->
                                            <StackPanel Grid.Column="2" MinWidth="280">
                                                <ComboBox ItemsSource="{Binding AvailableDevices}"
                                                          SelectedItem="{Binding SelectedAudioDevice}"
                                                          DisplayMemberPath="FriendlyName"/>

                                                <!-- Volume slider — only visible when a device is assigned -->
                                                <Grid Margin="0,10,0,0"
                                                      Visibility="{Binding HasDevice, Converter={StaticResource BoolToVis}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <wpfui:SymbolIcon Grid.Column="0" Symbol="Speaker224" FontSize="16"
                                                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                                            Value="{Binding Volume, Mode=TwoWay}"
                                                            VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Volume, StringFormat={}{0}%}"
                                                               FontSize="12" MinWidth="36" TextAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </wpfui:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Active Audio Sessions" FontSize="20" FontWeight="Medium" Margin="0,20,0,16"/>
                    </StackPanel>

                    <!-- Scrollable sessions card - only this scrolls internally -->
                    <Border Grid.Row="1" Margin="24,0,24,16" MinHeight="80"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ActiveSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Tag carries the row's session VM into the ContextMenu, which lives
                                                 outside the visual tree and can't reach DataContext directly. The
                                                 ContextMenuOpening handler reads it back via PlacementTarget.Tag. -->
                                            <Border Padding="20,10"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1" Background="Transparent"
                                                    Tag="{Binding}"
                                                    ContextMenuOpening="SessionRow_ContextMenuOpening">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem x:Name="PinToDeviceMenu" Header="Pin to device"/>
                                                        <Separator x:Name="PinSeparator"/>
                                                        <MenuItem x:Name="RemovePinMenu" Header="Remove pin"
                                                                  Click="RemovePin_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}" Width="20" Height="20"
                                                               Margin="0,0,10,0" VerticalAlignment="Center"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProcessName}" FontSize="13" FontWeight="Medium"/>
                                                            <TextBlock Text="{Binding ProcessId, StringFormat='PID {0}'}" FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding MonitorName}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="13" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <wpfui:SymbolIcon Symbol="Pin24" FontSize="14"
                                                                          Margin="0,0,6,0" VerticalAlignment="Center"
                                                                          Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                                          ToolTip="Pinned by an app override"
                                                                          Visibility="{Binding IsOverridden, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{Binding AudioDeviceName}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding ActiveSessions.Count, Converter={StaticResource ZeroToVis}}"
                                        IsHitTestVisible="False">
                                <wpfui:SymbolIcon Symbol="Speaker224" FontSize="32" Opacity="0.3"
                                                  HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="No active audio sessions" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Enable routing and play some audio" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ PINNED APPS PAGE ═══ -->
            <Border x:Name="PinnedPage" Visibility="Collapsed" Opacity="0">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <Grid Margin="24,20,24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Pinned Apps" FontSize="20" FontWeight="Medium"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0">
                            Pinned apps always play through the chosen device, regardless of which monitor
                            their window is on. Right-click an Active Session on the Home page to pin it.
                        </TextBlock>
                    </StackPanel>

                    <Border Grid.Row="1" MinHeight="80"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding AppOverrides}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="20,12"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1" Background="Transparent">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <wpfui:SymbolIcon Grid.Column="0" Symbol="Pin24" FontSize="18"
                                                                      Margin="0,0,12,0" VerticalAlignment="Center"
                                                                      Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding ProcessName}"
                                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding AudioDeviceName}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               FontSize="13" VerticalAlignment="Center"/>
                                                    <wpfui:Button Grid.Column="3" Icon="Delete24"
                                                                  Appearance="Transparent" Width="32" Height="32"
                                                                  ToolTip="Remove pin"
                                                                  Tag="{Binding}"
                                                                  Click="RemovePinFromList_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding AppOverrides.Count, Converter={StaticResource ZeroToVis}}"
                                        IsHitTestVisible="False">
                                <wpfui:SymbolIcon Symbol="Pin24" FontSize="32" Opacity="0.3"
                                                  HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="No pinned apps" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Right-click an Active Session on Home to pin it" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ SETTINGS PAGE ═══ -->
            <Border x:Name="SettingsPage" Visibility="Collapsed" Opacity="0">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,8">
                    <StackPanel>
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Medium" Margin="0,0,0,16"/>

                        <!-- Theme -->
                        <wpfui:CardControl Margin="0,0,0,8">
                            <wpfui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="DarkTheme24" FontSize="20"
                                                      Margin="0,0,14,0" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Theme" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Set light theme, dark theme or follow system settings" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl.Header>
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      SelectedIndex="{Binding SelectedThemeIndex}"
                                      MinWidth="120"/>
                        </wpfui:CardControl>

                        <!-- Run at startup -->
                        <wpfui:CardControl Margin="0,0,0,8">
                            <wpfui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="Power24" FontSize="20"
                                                      Margin="0,0,14,0" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Run at startup" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Automatically start when you sign in to Windows" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl.Header>
                            <wpfui:ToggleSwitch IsChecked="{Binding AutoStartWithWindows}"/>
                        </wpfui:CardControl>

                        <!-- Minimize on close -->
                        <wpfui:CardControl Margin="0,0,0,8">
                            <wpfui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="ArrowMinimize24" FontSize="20"
                                                      Margin="0,0,14,0" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Minimize on close" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Minimize to system tray instead of closing" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl.Header>
                            <wpfui:ToggleSwitch IsChecked="{Binding MinimizeOnClose}"/>
                        </wpfui:CardControl>

                        <!-- Start minimized -->
                        <wpfui:CardControl Margin="0,0,0,8">
                            <wpfui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <wpfui:SymbolIcon Symbol="EyeOff24" FontSize="20"
                                                      Margin="0,0,14,0" VerticalAlignment="Center"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Start minimized" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Launch hidden in the system tray" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl.Header>
                            <wpfui:ToggleSwitch IsChecked="{Binding StartMinimized}"/>
                        </wpfui:CardControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ ABOUT PAGE ═══ -->
            <Border x:Name="AboutPage" Visibility="Collapsed" Opacity="0">
                <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,8">
                    <StackPanel>
                        <TextBlock Text="About" FontSize="20" FontWeight="Medium" Margin="0,0,0,16"/>
                        <wpfui:Card Padding="24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <wpfui:SymbolIcon Symbol="Speaker224" FontSize="36"
                                                      Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                      VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Audio Monitor Router" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="Version 1.0.0" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,0,0,16"/>
                                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    Automatically routes audio output based on which monitor an application
                                    is displayed on. Apps on Monitor A play through Speaker A, apps on
                                    Monitor B play through Speaker B.
                                </TextBlock>
                                <TextBlock Text="Features" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,8"/>
                                <StackPanel Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#x2022;" Margin="0,0,8,0" Foreground="{DynamicResource PaletteGreenBrush}"/>
                                        <TextBlock Text="Per-app audio routing via Windows audio policy"
                                                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#x2022;" Margin="0,0,8,0" Foreground="{DynamicResource PaletteGreenBrush}"/>
                                        <TextBlock Text="Mixed-DPI multi-monitor support"
                                                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#x2022;" Margin="0,0,8,0" Foreground="{DynamicResource PaletteGreenBrush}"/>
                                        <TextBlock Text="Electron/Chromium app detection (Discord, VS Code, etc.)"
                                                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#x2022;" Margin="0,0,8,0" Foreground="{DynamicResource PaletteGreenBrush}"/>
                                        <TextBlock Text="Resets audio routing on exit"
                                                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </wpfui:Card>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</wpfui:UiWindow>
